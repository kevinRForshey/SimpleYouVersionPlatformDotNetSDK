@page "/oauth/callback"
@* Static SSR — no @rendermode so HttpContext is available during the request *@
@inject IYouVersionOAuthClient OAuthClient
@inject NavigationManager Nav
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Signing in…</PageTitle>

<div class="container mt-5 text-center">
    @if (_error is not null)
    {
        <div class="alert alert-danger">
            <h5>Sign-in failed</h5>
            <p>@_error</p>
            <a class="btn btn-primary" href="/">Return home</a>
        </div>
    }
    else
    {
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Completing sign-in…</span>
        </div>
        <p class="mt-3 text-muted">Completing sign-in, please wait…</p>
    }
</div>

@code {
    [SupplyParameterFromQuery] public string? Code { get; set; }
    [SupplyParameterFromQuery] public string? State { get; set; }
    [SupplyParameterFromQuery] public string? Error { get; set; }

    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(Error))
        {
            _error = $"Authorization denied: {Error}";
            return;
        }

        if (string.IsNullOrEmpty(Code))
        {
            _error = "No authorization code received.";
            return;
        }

        var ctx = HttpContextAccessor.HttpContext;
        var storedVerifier = ctx?.Session.GetString("pkce_verifier");
        var storedState = ctx?.Session.GetString("oauth_state");

        if (string.IsNullOrEmpty(storedVerifier))
        {
            _error = "Session expired. Please try signing in again.";
            return;
        }

        if (!string.IsNullOrEmpty(storedState) && storedState != State)
        {
            _error = "Invalid state parameter. Possible CSRF attempt.";
            return;
        }

        try
        {
            await OAuthClient.ExchangeCodeAsync(Code, storedVerifier);
            ctx?.Session.Remove("pkce_verifier");
            ctx?.Session.Remove("oauth_state");

            Nav.NavigateTo("/");
            // SSR NavigateTo issues a 302 redirect
        }
        catch (Exception ex)
        {
            _error = $"Token exchange failed: {ex.Message}";
        }
    }
}
